# Agent Flight Recorder Configuration
# Copy this file to .env and adjust values as needed.

# Optional API key for authentication.
# If set, all API requests must include: Authorization: Bearer <key>
# If unset, all requests are allowed (suitable for local development).
AFR_API_KEY=

# Backend server port (default: 3001)
PORT=3001

# SQLite database file path (default: backend/data.db)
DATABASE_URL=

# UI: Backend API URL (used by the Next.js frontend)
NEXT_PUBLIC_API_URL=http://localhost:3001/api
